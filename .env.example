# Project Manhattan — environment template.
# Copy to .env and fill in. NEVER commit a real .env (it is gitignored). On this PUBLIC
# repo, no real secret of any kind belongs in git — even encrypted (D6). Your fleet pulls
# the real .env from a private channel at bootstrap; public cloners bring their own keys.
# Put a HARD ~$50 spend cap on every paid provider's billing dashboard (C1).

# ── Coordination spine (REQUIRED — the swarm cannot run without these) ─────────
SUPABASE_URL=                 # https://<ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=    # agents are trusted infra; they use this
SUPABASE_DB_URL=              # postgres://...  (pooled) — used to apply spine/schema.sql
GITHUB_TOKEN=                 # fine-grained PAT: contents, pull_requests, issues, actions

# ── Identity of this worker (set per tab by swarm-up.sh) ───────────────────────
MANHATTAN_ROLE=               # e.g. developer | tester | architect | ceo | integrator ...
MANHATTAN_MACHINE=            # short host label, e.g. "mbp-1"

# ── Deploy target (REQUIRED for the product to ship) ──────────────────────────
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ── Optional AI (agents use only if they choose to — not forced) ──────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=            # for programmatic sub-agents/LLM calls beyond the CC session

# ── Blob storage (optional but provisioned so it's never a blocker) ───────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=                  # https://<acct>.r2.cloudflarestorage.com

# ── Heavy/long compute escape hatch (optional — see Runpod verdict in chat) ───
RUNPOD_API_KEY=

# ── "Never a blocker" extras (optional; fill if/when a feature needs them) ─────
RESEND_API_KEY=               # transactional email (auth, magic links)
UPSTASH_REDIS_REST_URL=       # serverless redis: rate-limit / ephemeral locks
UPSTASH_REDIS_REST_TOKEN=
SENTRY_DSN=                   # error visibility for dying agents
STRIPE_SECRET_KEY=            # TEST MODE ONLY if the product ever touches payments
CLOUDFLARE_API_TOKEN=         # DNS / R2 mgmt / Turnstile

# ── App secrets (random) ──────────────────────────────────────────────────────
AUTH_SECRET=                  # `openssl rand -base64 32`
